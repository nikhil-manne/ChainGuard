{
  "manifest_version": 3,
  "name": "ChainGuard",
  "version": "1.0",
  "description": "Blockchain-backed malware detection",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" }
}